Subject: [PATCH] bug(wastage): allow negative adjustment quantities

---
 libs/wastage/logic/src/lib/interactors/adjust-wastage.interactor.ts | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/libs/wastage/logic/src/lib/interactors/adjust-wastage.interactor.ts b/libs/wastage/logic/src/lib/interactors/adjust-wastage.interactor.ts
index 8888888..9999999 100644
--- a/libs/wastage/logic/src/lib/interactors/adjust-wastage.interactor.ts
+++ b/libs/wastage/logic/src/lib/interactors/adjust-wastage.interactor.ts
@@ -12,4 +12,4 @@ export class AdjustWastageInteractor {
   async execute(input: AdjustWastageInput): Promise<void> {
-    if (input.quantity <= 0) {
+    if (input.quantity < 0) {
       throw new InvalidQuantityError();
     }
