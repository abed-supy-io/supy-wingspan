#!/usr/bin/env bash
# Repo-local pre-commit guardrail — runs the same markdown checks CI runs, on
# staged files only, so doc rot fails before it leaves the machine.
#
# One-time setup after cloning:
#   git config core.hooksPath .githooks
#
# Bypass in an emergency with:  git commit --no-verify
set -uo pipefail

cd "$(git rev-parse --show-toplevel)" || exit 0

# Staged markdown only (added/copied/modified/renamed) — CHANGELOG.md is
# generated by release-please and exempt, same as in CI.
staged_md=()
while IFS= read -r f; do
  [ "$f" = "CHANGELOG.md" ] && continue
  staged_md+=("$f")
done < <(git diff --cached --name-only --diff-filter=ACMR -- '*.md')

if [ "${#staged_md[@]}" -gt 0 ]; then
  echo "pre-commit: markdownlint on ${#staged_md[@]} staged markdown file(s)"
  npx markdownlint-cli2 --config config/custom.markdownlint.jsonc "${staged_md[@]}" || {
    echo "pre-commit: markdownlint failed — fix or bypass with --no-verify"
    exit 1
  }

  echo "pre-commit: cspell on staged markdown"
  npx cspell --config config/cspell.json --no-progress "${staged_md[@]}" || {
    echo "pre-commit: cspell failed — add real project words to config/cspell.json"
    exit 1
  }
fi

# Staged shell scripts, when shellcheck is available locally.
staged_sh=()
while IFS= read -r f; do
  staged_sh+=("$f")
done < <(git diff --cached --name-only --diff-filter=ACMR -- '*.sh' '.githooks/*')

if [ "${#staged_sh[@]}" -gt 0 ] && command -v shellcheck >/dev/null 2>&1; then
  echo "pre-commit: shellcheck on ${#staged_sh[@]} staged shell file(s)"
  shellcheck "${staged_sh[@]}" || {
    echo "pre-commit: shellcheck failed — fix or bypass with --no-verify"
    exit 1
  }
fi

exit 0
