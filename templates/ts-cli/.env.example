# supy-cli — required environment keys (PLACEHOLDER VALUES ONLY — never commit a real secret).
# Copy to `.env` and per-environment `.env.development` / `.env.production`, then fill locally.
# The CLI resolves DEV_* vs PROD_* by the selected environment; the environment NAME flows through
# the CLI, never a raw connection string as an argument (architecture.md rules 4 & 6).

# Mongo credentials (shared across DBs).
MONGO_DB_USER=your-mongo-user
MONGO_DB_PASS=your-mongo-password

# Development connection URIs (one per database the CLI targets).
DEV_CATALOG_URI=mongodb://localhost:27017/catalog
DEV_INVENTORY_URI=mongodb://localhost:27017/inventory
DEV_CORE_URI=mongodb://localhost:27017/core

# Production connection URIs — filled ONLY in the deployment environment, never in VCS.
# A script that mutates any of these must gate behind an explicit confirmation (architecture.md rule 5).
PROD_CATALOG_URI=
PROD_INVENTORY_URI=
PROD_CORE_URI=
