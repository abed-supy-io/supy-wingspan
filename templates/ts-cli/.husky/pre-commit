#!/usr/bin/env sh
# supy-cli local guardrail — mirrors CI so feedback is instant.
# Install with: npx husky init  (then replace the generated pre-commit with this file).

# 1. BLOCK committed secrets / connection strings (secrets-and-config.md#rules rule 5).
#    Non-negotiable, runs first. Requires gitleaks on PATH: `brew install gitleaks`.
if ! command -v gitleaks >/dev/null 2>&1; then
  echo "pre-commit: gitleaks not found — install with 'brew install gitleaks' (secret scan is non-negotiable)." >&2
  exit 1
fi
gitleaks protect --staged --redact --no-banner

# 2. Lint + format only what's staged (fast).
npx lint-staged

# 3. Type-check the whole CLI (the compile guarantee the repo relies on before shipping a bin).
npm run typecheck

# 4. Coverage — fast local feedback: run the suite with coverage collection.
#    The hard floor is enforced by CI / the Jest coverageThreshold config, not this
#    hook (config/standards/ci-coverage-baseline.md rule 5; rule 7 keeps pre-commit fast).
npm test -- --coverage
