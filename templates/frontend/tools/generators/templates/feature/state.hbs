  }

  @Action({{pascal feature}}Create)
  create(ctx: StateContext<{{pascal feature}}StateModel>, { payload }: {{pascal feature}}Create) {
    return this.{{camel feature}}Service.create(payload).pipe(
      tap(created => this.setOne(ctx, created)),
    );
  }

  @Action({{pascal feature}}SetPage)
  setPage(ctx: StateContext<{{pascal feature}}StateModel>, { payload }: {{pascal feature}}SetPage) {
    const meta: BaseRequestMetadata = { ...ctx.getState().requestMetadata, page: payload.page };

    ctx.patchState({ requestMetadata: meta });

    return ctx.dispatch(new {{pascal feature}}GetMany());
  }
}
