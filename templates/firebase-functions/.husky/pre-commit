#!/usr/bin/env sh
# supy-firebase-functions local guardrail — mirrors CI so feedback is instant.
# Install with: npx husky init  (then replace the generated pre-commit with this file).

# 1. BLOCK committed secrets (secrets-and-config.md#rules rule 5). Non-negotiable, runs first.
#    Requires gitleaks on PATH: `brew install gitleaks`.
if ! command -v gitleaks >/dev/null 2>&1; then
  echo "pre-commit: gitleaks not found — install with 'brew install gitleaks' (secret scan is non-negotiable)." >&2
  exit 1
fi
gitleaks protect --staged --redact --no-banner

# 2. Lint + format only what's staged (fast).
npx lint-staged

# 3. Type-check the Functions package (the compile guarantee TSLint never gave).
npm --prefix functions run typecheck

# 4. Coverage bar (config/standards/ci-coverage-baseline.md rule 5 — a measured-but-ungated
#    coverage number is not a gate).
npm --prefix functions test -- --coverage
