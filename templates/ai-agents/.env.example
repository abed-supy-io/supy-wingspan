# supy-ai-agents — required environment keys (PLACEHOLDER VALUES ONLY — never commit a real secret).
# Polyglot monorepo: each package reads its own env through its config singleton. Copy the keys the
# package needs into that package's `.env` and fill locally; never commit the filled file. Workers
# (e.g. Gleap) use `wrangler secret put <NAME>` instead of a committed file. Secrets never flow on
# argv and are never logged (architecture.md rules 1 & 3).

# --- Knowledge graph (Cortex: PostgreSQL + pgvector) ---
KG_DATABASE_URL=postgres://user:password@localhost:5432/kg

# --- Redis / BullMQ (shared cluster config with fallback) ---
REDIS_URL=redis://localhost:6379

# --- Model / provider keys ---
OPENROUTER_KEY=

# --- OAuth 2.1 / JWT (Cortex oauth-server, Gleap) ---
OAUTH_CLIENT_ID=your-oauth-client-id
OAUTH_CLIENT_SECRET=
JWT_SIGNING_SECRET=

# --- Integrations ---
GLEAP_API_KEY=
SLACK_WEBHOOK=
